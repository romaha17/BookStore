@page "/"
@rendermode InteractiveServer
@inject IBookService BookService
@inject ICartService CartService
@inject IPurchaseService PurchaseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<link rel="stylesheet" href="~/app.css" />

<BookAssistantChat AvailableBooks="@(pagedResult?.Items ?? new())" />

<div class="top-bar">
    <div class="logo">
        <h2>BookStore</h2>
    </div>

    <SearchFilters Genres="genres" Languages="languages" OnSearch="OnSearch" />

    <div class="cart">
        <a href="/cartpage">
            <span class="cart-icon">🛒</span>
            <span class="cart-count">@cartItemCount</span>
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;">
        <div class="toast show align-items-center text-white bg-danger border-0 shadow" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">@errorMessage</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        </div>
    </div>
}

@if (pagedResult == null)
{
    <p>Loading...</p>
}
else if (!pagedResult.Items.Any())
{
    <p class="text-center">No books found.</p>
}
else
{
    <div class="container mt-4">
        <div class="row">
            @foreach (var book in pagedResult.Items)
            {
                <BookCard Book="book"
                          IsAdmin="isAdmin"
                          IsOwned="purchasedBookIds.Contains(book.Id)"
                          OnAddToCart="AddToCart"
                          OnAddToLibrary="AddToLibrary"
                          OnNavigateToPurchased="NavigateToPurchasedBooks" />
            }
        </div>
    </div>

    <Pagination CurrentPage="currentFilter.Page"
                TotalPages="pagedResult.TotalPages"
                OnPageChange="LoadPage" />
}

@code {
    private PagedResultDto<BookDto>? pagedResult;
    private List<string> genres = new();
    private List<string> languages = new();
    private HashSet<int> purchasedBookIds = new();
    private int cartItemCount;
    private bool isAdmin;
    private string? userId;
    private string errorMessage = "";
    private BookFilterDto currentFilter = new() { Page = 1, PageSize = 9 };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        isAdmin = user.IsInRole("Admin");

        genres = await BookService.GetGenresAsync();
        languages = await BookService.GetLanguagesAsync();

        await LoadPage(1);

        if (!string.IsNullOrEmpty(userId))
        {
            var purchased = await PurchaseService.GetPurchasedBooksAsync(userId);
            purchasedBookIds = purchased.Select(b => b.Id).ToHashSet();

            var cart = await CartService.GetCartAsync(userId);
            cartItemCount = cart.Items.Count;
        }
    }

    private async Task OnSearch(BookFilterDto filter)
    {
        currentFilter = new BookFilterDto
        {
            Query = filter.Query,
            Genre = filter.Genre,
            Language = filter.Language,
            MaxPrice = filter.MaxPrice,
            Page = 1,
            PageSize = 9
        };
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        currentFilter.Page = page;
        pagedResult = await BookService.GetPagedBooksAsync(currentFilter);
    }

    private async Task AddToCart(int bookId)
    {
        if (string.IsNullOrEmpty(userId))
        {
            NavigationManager.NavigateTo($"/Account/Login?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
            return;
        }

        try
        {
            await CartService.AddItemAsync(userId, bookId);
            cartItemCount++;
            errorMessage = string.Empty;
        }
        catch (BookStore.Domain.Exceptions.BookAlreadyInCartException)
        {
            errorMessage = "You already have this book in your cart.";
        }
    }

    private async Task AddToLibrary(int bookId)
    {
        if (string.IsNullOrEmpty(userId)) return;
        try
        {
            await PurchaseService.AddToLibraryAsync(userId, bookId);
            purchasedBookIds.Add(bookId);
        }
        catch (BookStore.Domain.Exceptions.BookAlreadyPurchasedException) { }
    }

    private void NavigateToPurchasedBooks()
        => NavigationManager.NavigateTo("/PurchasedBooks");
}
