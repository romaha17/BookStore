@page "/BookPage/{id:int}"
@rendermode InteractiveServer
@inject IBookService BookService
@inject ICartService CartService
@inject IPurchaseService PurchaseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<link rel="stylesheet" href="error.css" />

<div class="container my-5">
    @if (book == null)
    {
        <p>Loading...</p>
    }
    else
    {
        <div class="card shadow-lg p-4">
            <div class="row g-4 align-items-center">
                <div class="col-md-4 text-center">
                    <img src="@GetImageUrl(book.ImagePath)" class="img-fluid rounded" alt="@book.BookName" style="max-height: 400px;" />
                </div>

                <div class="col-md-8">
                    <h2 class="fw-bold">@book.BookName</h2>
                    <p class="mb-2"><strong>Genre:</strong> @book.Genre</p>
                    <p class="mb-2"><strong>Price:</strong> @(isAdmin ? "$0.00" : $"${book.Price:0.00}")</p>
                    <p class="mb-2"><strong>Published:</strong> @book.DateOfPublishment.ToString("MMMM dd, yyyy")</p>
                    <p class="mb-2"><strong>Languages:</strong> @book.AvailableLanguage</p>
                    <p class="mb-2"><strong>Authors:</strong> @string.Join(", ", book.Authors.Select(a => $"{a.FirstName} {a.LastName}"))</p>

                    <p class="mt-4">@book.SmallDescription</p>

                    <div class="mt-4 d-flex flex-wrap gap-2">
                        @if (isOwned)
                        {
                            <button class="btn btn-primary" @onclick="GoToPurchasedBooks">Already owned</button>
                        }
                        else if (isAdmin)
                        {
                            <button class="btn btn-info" @onclick="AddToLibrary">Add to Library (Free)</button>
                        }
                        else
                        {
                            <button class="btn btn-success" @onclick="AddToCart">Add to cart</button>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-warning mt-4 d-flex justify-content-between align-items-center">
                            <span>@errorMessage</span>
                            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int id { get; set; }

    private BookDto? book;
    private string errorMessage = "";
    private string? userId;
    private bool isOwned;
    private bool isAdmin;

    protected override async Task OnInitializedAsync()
    {
        book = await BookService.GetBookByIdAsync(id);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
        isAdmin = user.IsInRole("Admin");

        if (!string.IsNullOrEmpty(userId) && book is not null)
            isOwned = await PurchaseService.HasPurchasedAsync(userId, book.Id);
    }

    private async Task AddToLibrary()
    {
        if (string.IsNullOrEmpty(userId) || book is null) return;
        try
        {
            await PurchaseService.AddToLibraryAsync(userId, book.Id);
            isOwned = true;
        }
        catch (BookStore.Domain.Exceptions.BookAlreadyPurchasedException) { isOwned = true; }
    }

    private async Task AddToCart()
    {
        if (string.IsNullOrEmpty(userId))
        {
            NavigationManager.NavigateTo($"/Account/Login?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
            return;
        }

        try
        {
            await CartService.AddItemAsync(userId, book!.Id);
            errorMessage = string.Empty;
        }
        catch (BookStore.Domain.Exceptions.BookAlreadyInCartException)
        {
            errorMessage = "You already have this book in your cart.";
        }
    }

    private void GoToPurchasedBooks()
        => NavigationManager.NavigateTo("/PurchasedBooks");

    private string GetImageUrl(string imagePath)
    {
        var version = Guid.NewGuid().ToString();
        return $"https://bookstore-media228.s3.eu-north-1.amazonaws.com{imagePath}?v={version}";
    }
}
