@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IBookService BookService
@inject IStorageService StorageService
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-info">@statusMessage</div>
}

@if (pagedResult == null)
{
    <p><em>Loading books...</em></p>
}
else
{
    <table class="table admin-books-table table-striped align-middle">
        <thead class="table-dark">
            <tr><th>Image</th><th>Name</th><th>Genre</th><th>Price</th><th>Language</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var book in pagedResult.Items)
            {
                <tr>
                    <td>@if (!string.IsNullOrEmpty(book.ImagePath)) { <img src="@GetImageUrl(book.ImagePath)" style="max-height: 80px;" alt="Cover" /> }</td>
                    <td title="@book.SmallDescription">@book.BookName</td>
                    <td>@book.Genre</td>
                    <td>@($"${book.Price:0.00}")</td>
                    <td>@book.AvailableLanguage</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditBook(book)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="async () => await DeleteBook(book.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <Pagination CurrentPage="pagedResult.CurrentPage" TotalPages="pagedResult.TotalPages" OnPageChange="LoadBooks" />

    <hr />
    <h4 class="mt-5">@((selectedBook.Id == 0) ? "Add New Book" : "Edit Book")</h4>

    <EditForm Model="@selectedBook" OnValidSubmit="@SaveBook" class="admin-form mt-3">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="form-group"><label>Name:</label><InputText class="form-control" @bind-Value="selectedBook.BookName" /></div>
        <div class="form-group"><label>Genre:</label><InputText class="form-control" @bind-Value="selectedBook.Genre" /></div>
        <div class="form-group"><label>Authors (comma-separated):</label><InputText class="form-control" @bind-Value="authorsInput" /></div>
        <div class="form-group"><label>Price:</label><InputNumber class="form-control" @bind-Value="selectedBook.Price" /></div>
        <div class="form-group"><label>Language:</label><InputText class="form-control" @bind-Value="selectedBook.AvailableLanguage" /></div>
        <div class="form-group"><label>Description:</label><InputTextArea class="form-control" @bind-Value="selectedBook.SmallDescription" Rows="4" /></div>
        <div class="form-group">
            <label>Cover Image:</label>
            <div class="custom-file-upload">
                <label class="btn btn-outline-primary btn-sm">Upload Image <InputFile OnChange="OnImageUpload" accept="image/*" class="d-none" /></label>
                @if (uploadedImage != null) { <span class="ms-2">@uploadedImage.Name</span> }
            </div>
        </div>
        <div class="form-group">
            <label>PDF File:</label>
            <div class="custom-file-upload">
                <label class="btn btn-outline-primary btn-sm">Upload PDF <InputFile OnChange="OnPdfUpload" accept=".pdf" class="d-none" /></label>
                @if (uploadedPdf != null) { <span class="ms-2">@uploadedPdf.Name</span> }
            </div>
        </div>
        <div class="form-group mt-3">
            <button class="btn btn-success me-2" type="submit">Save</button>
            <button class="btn btn-secondary" type="button" @onclick="ResetForm">Cancel</button>
        </div>
    </EditForm>
}

@code {
    private PagedResultDto<BookDto>? pagedResult;
    private BookDto selectedBook = new();
    private string statusMessage = "";
    private IBrowserFile? uploadedImage;
    private IBrowserFile? uploadedPdf;
    private string authorsInput = "";

    protected override async Task OnInitializedAsync() => await LoadBooks(1);

    private async Task LoadBooks(int page = 1)
        => pagedResult = await BookService.GetPagedBooksAsync(new BookFilterDto { Page = page, PageSize = 5 });

    private void EditBook(BookDto book)
    {
        selectedBook = new BookDto
        {
            Id = book.Id, BookName = book.BookName, Genre = book.Genre, Price = book.Price,
            AvailableLanguage = book.AvailableLanguage, ImagePath = book.ImagePath,
            SmallDescription = book.SmallDescription, Authors = book.Authors
        };
        authorsInput = string.Join(", ", book.Authors.Select(a => $"{a.FirstName} {a.LastName}"));
    }

    private async Task SaveBook()
    {
        var authorsList = authorsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(n => n.Trim()).Where(n => n.Length > 0).Distinct()
            .Select(full => { var p = full.Split(' ', 2); return new AuthorDto { FirstName = p[0], LastName = p.Length > 1 ? p[1] : "" }; })
            .ToList();
        selectedBook.Authors = authorsList;
        if (selectedBook.Id == 0) { await BookService.CreateBookAsync(selectedBook); statusMessage = $"Book {selectedBook.BookName} added!"; }
        else { await BookService.UpdateBookAsync(selectedBook); statusMessage = $"Book {selectedBook.BookName} updated!"; }
        await LoadBooks(pagedResult?.CurrentPage ?? 1);
        ResetForm();
    }

    private async Task DeleteBook(int id)
    {
        var book = pagedResult?.Items.FirstOrDefault(b => b.Id == id);
        if (book is not null)
        {
            if (!string.IsNullOrEmpty(book.ImagePath)) await StorageService.DeleteFileAsync(book.ImagePath);
            await BookService.DeleteBookAsync(id);
            await LoadBooks(pagedResult?.CurrentPage ?? 1);
            statusMessage = $"Book {book.BookName} deleted.";
        }
    }

    private void ResetForm() { selectedBook = new BookDto(); authorsInput = ""; uploadedImage = null; uploadedPdf = null; }

    private async Task OnImageUpload(InputFileChangeEventArgs e)
    {
        uploadedImage = e.File;
        var key = $"/images/books/book-TEMP-{GenerateSlug(selectedBook.BookName)}{Path.GetExtension(uploadedImage.Name)}";
        using var stream = uploadedImage.OpenReadStream(10_000_000);
        await StorageService.UploadFileAsync(stream, key, uploadedImage.ContentType);
        selectedBook.ImagePath = key;
    }

    private async Task OnPdfUpload(InputFileChangeEventArgs e)
    {
        uploadedPdf = e.File;
        var key = $"/pdf/book-TEMP-{GenerateSlug(selectedBook.BookName)}{Path.GetExtension(uploadedPdf.Name)}";
        using var stream = uploadedPdf.OpenReadStream(50_000_000);
        await StorageService.UploadFileAsync(stream, key, uploadedPdf.ContentType);
    }

    private string GetImageUrl(string path) => $"https://bookstore-media228.s3.eu-north-1.amazonaws.com{path}?v={Guid.NewGuid()}";

    private static string GenerateSlug(string input)
        => input.ToLower().Replace(" ", "-").Replace("'", "").Replace(",", "").Replace(".", "").Replace(":", "").Replace(";", "").Replace("--", "-");
}
