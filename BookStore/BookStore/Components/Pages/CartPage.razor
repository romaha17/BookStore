@page "/cartpage"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ICartService CartService
@inject IStripeCheckoutService StripeCheckoutService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<h1 class="mt-4">Your Shopping Cart</h1>

@if (cart == null)
{
    <p>Loading your cart...</p>
}
else if (!cart.Items.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Book</th>
                <th>Price</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in cart.Items)
            {
                <tr>
                    <td>@item.BookName</td>
                    <td>@item.Price.ToString("C")</td>
                    <td class="text-end">
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveItem(item.Id)">
                            <i class="bi bi-x-circle"></i> Remove
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h4 class="mt-3">Total: <span class="text-success fw-bold">@cart.Items.Sum(i => i.Price).ToString("C")</span></h4>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <form method="post" @formname="checkout-form" @onsubmit="CheckoutAsync">
            <AntiforgeryToken />
            <button type="submit" id="checkout-button" class="btn btn-success">
                <i class="bi bi-credit-card"></i> Checkout
            </button>
        </form>

        <button class="btn btn-warning" @onclick="ClearCart">
            <i class="bi bi-trash3"></i> Clear Cart
        </button>
    </div>
}

@code {
    private CartDto? cart;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrEmpty(userId))
        {
            NavigationManager.NavigateTo("/Account/Login");
            return;
        }

        cart = await CartService.GetCartAsync(userId);
    }

    private async Task RemoveItem(int cartItemId)
    {
        if (cart is null || userId is null) return;
        await CartService.RemoveItemAsync(userId, cartItemId);
        cart = await CartService.GetCartAsync(userId);
    }

    private async Task ClearCart()
    {
        if (userId is null) return;
        await CartService.ClearCartAsync(userId);
        cart = await CartService.GetCartAsync(userId);
    }

    private async Task CheckoutAsync()
    {
        if (cart is null || !cart.Items.Any()) return;

        var domain = NavigationManager.BaseUri.TrimEnd('/');
        var successUrl = $"{domain}/payment-success?session_id={{CHECKOUT_SESSION_ID}}";
        var cancelUrl = domain;

        var sessionUrl = await StripeCheckoutService.CreateCheckoutSessionAsync(cart, successUrl, cancelUrl);
        NavigationManager.NavigateTo(sessionUrl);
    }
}
